  "keyFeatures": [
    "Non-custodial vault management with ERC-4626 compliance",
    "Adapter-based allocation to multiple markets",
    "Multi-role access control (Owner, Curator, Allocator, Sentinel)",
    "Risk management with absolute and relative caps",
    "Timelocked configuration changes for security",
    "In-kind redemptions with force deallocate",
    "Configurable gates for transfers and deposits",
    "Performance and management fee system"
  ],
